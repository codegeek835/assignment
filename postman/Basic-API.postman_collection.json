{
  "info": {
    "_postman_id": "a1b2c3d4-basic-api-users",
    "name": "Basic API — Users",
    "description": "Requests for the assignment `basic-api` Express server (`/signup`, `/login`, `/users`, `/alerts`).\n\nImport **Basic-API.local.postman_environment.json** or set collection variables `baseUrl`, `username`, `email`, `password`. Password must be 8–256 characters; **signup** requires a valid email. **Login** accepts **either** `username` **or** `email` with `password` (not both)—use **Login (username)** or **Login (email)**.\n\n**Signup** and **Login** save the returned JWT into the `token` collection variable; **List Users** sends it as `Authorization: Bearer {{token}}`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "username",
      "value": "alice"
    },
    {
      "key": "email",
      "value": "alice@example.com"
    },
    {
      "key": "password",
      "value": "secretpass1"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body && body.token) { pm.collectionVariables.set('token', body.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/signup",
            "description": "Registers a user. Expect **201** with `{ msg, id, username, email, token }`. The test script stores `token` in the collection variable for **List Users**. Duplicate username or email → **409**. Invalid email → **400**."
          },
          "response": []
        },
        {
          "name": "Login (username)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body && body.token) { pm.collectionVariables.set('token', body.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/login",
            "description": "Send **username** + **password** only. Expect **200** with `{ msg, id, username, email, token }` or **401**. Do not send `email` at the same time. Token is stored in the `token` collection variable."
          },
          "response": []
        },
        {
          "name": "Login (email)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body && body.token) { pm.collectionVariables.set('token', body.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/login",
            "description": "Send **email** + **password** only. Same responses as username login. Token is stored in the `token` collection variable."
          },
          "response": []
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/users",
            "description": "Returns JSON array of `{ \"id\", \"username\", \"email\" }` (no passwords). Requires the JWT obtained from **Signup** or **Login**; **401** if missing or invalid."
          },
          "response": []
        },
        {
          "name": "Get alerts",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/alerts",
            "description": "Suspicious IPs from the access log written by this API. Any response with `STATUS=401` or `STATUS=403` counts as a failed attempt; empty array until enough failures land in the sliding window."
          },
          "response": []
        }
      ]
    }
  ]
}
