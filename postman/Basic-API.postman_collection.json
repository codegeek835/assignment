{
  "info": {
    "_postman_id": "a1b2c3d4-basic-api-users",
    "name": "Basic API — Users",
    "description": "Requests for the assignment `basic-api` Express server (`/createUser`, `/login`, `/users`).\n\nImport **Basic-API.local.postman_environment.json** or set collection variables `baseUrl`, `username`, `email`, `password`. Password must be 8–256 characters; **createUser** requires a valid email. **Login** accepts **either** `username` **or** `email` with `password` (not both)—use **Login (username)** or **Login (email)**.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "username",
      "value": "alice"
    },
    {
      "key": "email",
      "value": "alice@example.com"
    },
    {
      "key": "password",
      "value": "secretpass1"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/createUser",
            "description": "Registers a user. Expect **201** with `{ \"msg\": \"user created\" }`. Duplicate username or email → **409** (`Username already exists` / `Email already registered`). Invalid email → **400**."
          },
          "response": []
        },
        {
          "name": "Login (username)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/login",
            "description": "Send **username** + **password** only. Expect **200** or **401**. Do not send `email` at the same time."
          },
          "response": []
        },
        {
          "name": "Login (email)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/login",
            "description": "Send **email** + **password** only. Same responses as username login."
          },
          "response": []
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/users",
            "description": "Returns JSON array of `{ \"id\", \"username\", \"email\" }` (no passwords)."
          },
          "response": []
        },
        {
          "name": "Get alerts",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/alerts",
            "description": "Suspicious IPs from failed-login lines written by this API (`401` on `/login`). Empty array until enough failures in the sliding window."
          },
          "response": []
        }
      ]
    }
  ]
}
